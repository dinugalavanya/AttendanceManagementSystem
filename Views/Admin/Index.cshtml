@model AttendanceManagementSystem.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Admin Dashboard</h1>
        <p class="text-muted mb-0">Operational summary for today</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Total Users</div>
                <div class="display-6 fw-semibold">@Model.TotalUsers</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Today Attendance</div>
                <div class="display-6 fw-semibold">@Model.TodayAttendance</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Present</div>
                <div class="h3 text-success">@Model.PresentCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Late</div>
                <div class="h3 text-warning">@Model.LateCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Absent</div>
                <div class="h3 text-danger">@Model.AbsentCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-body">
        <p class="mb-0">Active sections: <strong>@Model.TotalSections</strong></p>
    </div>
</div>

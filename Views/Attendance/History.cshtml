@model AttendanceManagementSystem.ViewModels.AttendanceHistoryViewModel
@{
    ViewData["Title"] = "My Attendance History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="bi bi-clock-history me-2"></i>My Attendance History
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Single Date Picker -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <form method="get" class="d-flex align-items-end gap-2">
                                <div class="flex-grow-1">
                                    <label for="selectedDate" class="form-label">Select Date</label>
                                    <input type="date" id="selectedDate" name="selectedDate" class="form-control"
                                           value="@(Model.SelectedDate?.ToString("yyyy-MM-dd") ?? "")">
                                </div>
                                <div>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-calendar-check me-1"></i>View
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Selected Day Summary Card -->
                    @if (Model.SelectedDate.HasValue)
                    {
                        if (Model.SelectedDateRecord != null)
                        {
                            <div class="card bg-light mb-4" style="border: 2px solid #7c3aed;">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">Attendance for @Model.SelectedDate.Value.ToString("dd MMM yyyy")</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <div class="stat-box">
                                                <div class="stat-icon-wrapper">
                                                    <i class="bi bi-clock-in stat-icon"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-label">In Time</div>
                                                    <div class="stat-value">
                                                        @(Model.SelectedDateRecord.InTime.HasValue ? Model.SelectedDateRecord.InTime.Value.ToString(@"hh\:mm") : "-")
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="stat-box">
                                                <div class="stat-icon-wrapper">
                                                    <i class="bi bi-clock-out stat-icon"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-label">Out Time</div>
                                                    <div class="stat-value">
                                                        @(Model.SelectedDateRecord.OutTime.HasValue ? Model.SelectedDateRecord.OutTime.Value.ToString(@"hh\:mm") : "-")
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="stat-box">
                                                <div class="stat-icon-wrapper">
                                                    <i class="bi bi-info-circle stat-icon"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-label">Status</div>
                                                    <div class="stat-value">@Model.SelectedDateRecord.Status</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="stat-box">
                                                <div class="stat-icon-wrapper">
                                                    <i class="bi bi-hourglass-split stat-icon"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-label">Worked Hours</div>
                                                    <div class="stat-value">
                                                        @(Model.SelectedDateRecord.TotalWorkedMinutes > 0 ?
                                                            $"{Model.SelectedDateRecord.TotalWorkedMinutes / 60:D2}:{Model.SelectedDateRecord.TotalWorkedMinutes % 60:D2}" : "-")
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="stat-box @(Model.SelectedDateRecord.OvertimeMinutes > 0 ? "stat-highlight" : "")">
                                                <div class="stat-icon-wrapper @(Model.SelectedDateRecord.OvertimeMinutes > 0 ? "bg-purple" : "")">
                                                    <i class="bi bi-clock-history stat-icon"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-label">OT Hours</div>
                                                    <div class="stat-value @(Model.SelectedDateRecord.OvertimeMinutes > 0 ? "text-purple" : "")">
                                                        @(Model.SelectedDateRecord.OvertimeMinutes > 0 ?
                                                            $"{Model.SelectedDateRecord.OvertimeMinutes / 60:D2}:{Model.SelectedDateRecord.OvertimeMinutes % 60:D2}" : "0h 0m")
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="stat-box">
                                                <div class="stat-icon-wrapper">
                                                    <i class="bi bi-card-text stat-icon"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-label">Notes</div>
                                                    <div class="stat-value">
                                                        @(!string.IsNullOrEmpty(Model.SelectedDateRecord.Notes) ? Model.SelectedDateRecord.Notes : "-")
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-4">
                                <i class="bi bi-info-circle me-2"></i>
                                No attendance record found for @Model.SelectedDate.Value.ToString("dd MMM yyyy").
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info mb-4">
                            <i class="bi bi-info-circle me-2"></i>
                            Please select a date to view attendance details.
                        </div>
                    }

                    <!-- Select Time Period Section -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="bi bi-calendar-range me-2"></i>Select Time Period
                            </h5>
                        </div>
                        <div class="card-body">
                            <form method="get" class="d-flex align-items-end gap-2">
                                <div class="flex-grow-1">
                                    <label for="periodStartDate" class="form-label">Start Date</label>
                                    <input type="date" id="periodStartDate" name="periodStartDate" class="form-control"
                                           value="@(Model.PeriodStartDate?.ToString("yyyy-MM-dd") ?? "")">
                                </div>
                                <div class="flex-grow-1">
                                    <label for="periodEndDate" class="form-label">End Date</label>
                                    <input type="date" id="periodEndDate" name="periodEndDate" class="form-control"
                                           value="@(Model.PeriodEndDate?.ToString("yyyy-MM-dd") ?? "")">
                                </div>
                                <div>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-search me-1"></i>Filter
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Period Records Table -->
                    @if (Model.PeriodRecords != null && Model.PeriodRecords.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Date</th>
                                        <th>In Time</th>
                                        <th>Out Time</th>
                                        <th>Status</th>
                                        <th>Worked Hours</th>
                                        <th>OT Hours</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var attendance in Model.PeriodRecords.OrderByDescending(a => a.AttendanceDate))
                                    {
                                        <tr>
                                            <td>@attendance.AttendanceDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                @if (attendance.InTime.HasValue)
                                                {
                                                    @attendance.InTime.Value.ToString(@"hh\:mm")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (attendance.OutTime.HasValue)
                                                {
                                                    @attendance.OutTime.Value.ToString(@"hh\:mm")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (attendance.Status)
                                                {
                                                    case "Present":
                                                        <span class="badge bg-success">On Time</span>
                                                        break;
                                                    case "Late":
                                                        <span class="badge bg-warning">Late</span>
                                                        break;
                                                    case "Absent":
                                                        <span class="badge bg-danger">Absent</span>
                                                        break;
                                                    case "Leave":
                                                        <span class="badge bg-info">Leave</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@attendance.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (attendance.TotalWorkedMinutes > 0)
                                                {
                                                    var hours = attendance.TotalWorkedMinutes / 60;
                                                    var minutes = attendance.TotalWorkedMinutes % 60;
                                                    @($"{hours:D2}:{minutes:D2}")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (attendance.OvertimeMinutes > 0)
                                                {
                                                    var hours = attendance.OvertimeMinutes / 60;
                                                    var minutes = attendance.OvertimeMinutes % 60;
                                                    @($"{hours:D2}:{minutes:D2}")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(attendance.Notes))
                                                {
                                                    @attendance.Notes
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Summary Statistics - Total Overtime Only -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card bg-light" style="border: 2px solid #7c3aed;">
                                    <div class="card-body text-center py-4">
                                        <h5 class="text-muted mb-2">Total Overtime</h5>
                                        <h2 class="mb-0 text-purple fw-bold" style="color: #7c3aed; font-size: 3rem;">
                                            @{
                                                var totalOTMinutes = Model.PeriodRecords.Sum(a => a.OvertimeMinutes);
                                                var totalOTHours = totalOTMinutes / 60;
                                                var totalOTMinutesRem = totalOTMinutes % 60;
                                            }
                                            @($"{totalOTHours:D2}:{totalOTMinutesRem:D2}")
                                        </h2>
                                        <small class="text-muted">Total overtime for selected period</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else if (Model.PeriodStartDate.HasValue && Model.PeriodEndDate.HasValue)
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                            <h5 class="text-muted mt-3">No attendance records found.</h5>
                            <p class="text-muted">There are no attendance records for the selected time period.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Set max date to today for date inputs
        document.addEventListener('DOMContentLoaded', function() {
            const today = new Date().toISOString().split('T')[0];

            // Set max date for all date inputs
            const dateInputs = document.querySelectorAll('input[type="date"]');
            dateInputs.forEach(input => {
                input.max = today;
            });

            // Ensure end date is not before start date
            const periodStartDate = document.getElementById('periodStartDate');
            const periodEndDate = document.getElementById('periodEndDate');

            if (periodStartDate) {
                periodStartDate.addEventListener('change', function() {
                    if (periodEndDate) {
                        periodEndDate.min = this.value;
                    }
                });
            }
        });
    </script>
}

@model AttendanceManagementSystem.ViewModels.AttendanceHistoryViewModel
@{
    ViewData["Title"] = "My Attendance History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="bi bi-clock-history me-2"></i>My Attendance History
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Date Range Filter -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <form method="get" class="d-flex align-items-end gap-2">
                                <div class="flex-grow-1">
                                    <label for="startDate" class="form-label">Start Date</label>
                                    <input type="date" id="startDate" name="startDate" class="form-control" 
                                           value="@Model.StartDate.ToString("yyyy-MM-dd")">
                                </div>
                                <div class="flex-grow-1">
                                    <label for="endDate" class="form-label">End Date</label>
                                    <input type="date" id="endDate" name="endDate" class="form-control" 
                                           value="@Model.EndDate.ToString("yyyy-MM-dd")">
                                </div>
                                <div>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-search me-1"></i>Filter
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Attendance Records Table -->
                    @if (Model.Attendances != null && Model.Attendances.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Date</th>
                                        <th>In Time</th>
                                        <th>Out Time</th>
                                        <th>Status</th>
                                        <th>Worked Hours</th>
                                        <th>OT Hours</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var attendance in Model.Attendances.OrderByDescending(a => a.AttendanceDate))
                                    {
                                        <tr>
                                            <td>@attendance.AttendanceDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                @if (attendance.InTime.HasValue)
                                                {
                                                    @attendance.InTime.Value.ToString(@"hh\:mm")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (attendance.OutTime.HasValue)
                                                {
                                                    @attendance.OutTime.Value.ToString(@"hh\:mm")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (attendance.Status)
                                                {
                                                    case "Present":
                                                        <span class="badge bg-success">On Time</span>
                                                        break;
                                                    case "Late":
                                                        <span class="badge bg-warning">Late</span>
                                                        break;
                                                    case "Absent":
                                                        <span class="badge bg-danger">Absent</span>
                                                        break;
                                                    case "Leave":
                                                        <span class="badge bg-info">Leave</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@attendance.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (attendance.TotalWorkedMinutes > 0)
                                                {
                                                    var hours = attendance.TotalWorkedMinutes / 60;
                                                    var minutes = attendance.TotalWorkedMinutes % 60;
                                                    @($"{hours:D2}:{minutes:D2}")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (attendance.OvertimeMinutes > 0)
                                                {
                                                    var hours = attendance.OvertimeMinutes / 60;
                                                    var minutes = attendance.OvertimeMinutes % 60;
                                                    @($"{hours:D2}:{minutes:D2}")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(attendance.Notes))
                                                {
                                                    @attendance.Notes
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Summary Statistics - Total Overtime Only -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card bg-light" style="border: 2px solid #7c3aed;">
                                    <div class="card-body text-center py-4">
                                        <h5 class="text-muted mb-2">Total Overtime</h5>
                                        <h2 class="mb-0 text-purple fw-bold" style="color: #7c3aed; font-size: 3rem;">
                                            @{
                                                var totalOTMinutes = Model.Attendances.Sum(a => a.OvertimeMinutes);
                                                var totalOTHours = totalOTMinutes / 60;
                                                var totalOTMinutesRem = totalOTMinutes % 60;
                                            }
                                            @($"{totalOTHours:D2}:{totalOTMinutesRem:D2}")
                                        </h2>
                                        <small class="text-muted">Total overtime for selected period</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                            <h5 class="text-muted mt-3">No attendance history found.</h5>
                            <p class="text-muted">There are no attendance records for the selected date range.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Set max date to today for date inputs
        document.addEventListener('DOMContentLoaded', function() {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('startDate').max = today;
            document.getElementById('endDate').max = today;
            
            // Ensure end date is not before start date
            document.getElementById('startDate').addEventListener('change', function() {
                document.getElementById('endDate').min = this.value;
            });
        });
    </script>
}

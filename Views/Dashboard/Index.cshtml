@model DashboardViewModel
@using System.Text.Json
@using AttendanceManagementSystem.Models
@{
    ViewData["Title"] = "Dashboard";

    var roleLabel = Model.IsSuperAdmin ? "SuperAdmin" : Model.IsAdmin ? "Admin" : "Worker";
    var roleTone = Model.IsSuperAdmin ? "super" : Model.IsAdmin ? "admin" : "worker";
    var attendanceRate = Model.AttendanceTargetPercent;
    var monthlyLeaveCount = Model.DistributionValues.Count > 3 ? Model.DistributionValues[3] : 0;
    var currentMonthLabel = Model.SelectedDate.ToString("MMMM yyyy");

    var header = new PageHeaderViewModel
    {
        Eyebrow = "People Operations",
        Title = Model.IsWorker ? "My Attendance Dashboard" : "Attendance Command Center",
        Subtitle = Model.ScopeTitle,
        Badges = new List<PageHeaderBadgeViewModel>
        {
            new() { Text = roleLabel, Tone = roleTone, Icon = "bi-person-badge" },
            new() { Text = currentMonthLabel, Tone = "neutral", Icon = "bi-calendar3" }
        }
    };

    var cards = new List<SummaryCardViewModel>();
    var selectedDateLabel = Model.SelectedDate == DateTime.Today ? "Today" : Model.SelectedDate.ToString("MMM dd");
    
    if (Model.IsWorker)
    {
        cards.AddRange(new List<SummaryCardViewModel>
        {
            new() { Label = $"My Records {selectedDateLabel}", Value = Model.TodayAttendance.ToString(), Icon = "bi-person-check", Tone = "neutral", HelperText = $"Daily attendance entries for {selectedDateLabel}" },
            new() { Label = "Present This Month", Value = Model.MonthlyPresentCount.ToString(), Icon = "bi-check2-circle", Tone = "success", HelperText = "On-time or valid attendance" },
            new() { Label = "Late This Month", Value = Model.MonthlyLateCount.ToString(), Icon = "bi-alarm", Tone = "warning", HelperText = "Arrivals beyond grace period" },
            new() { Label = "Absent This Month", Value = Model.MonthlyAbsentCount.ToString(), Icon = "bi-x-circle", Tone = "danger", HelperText = "Days marked absent" },
            new() { Label = "Leave This Month", Value = monthlyLeaveCount.ToString(), Icon = "bi-person-dash", Tone = "sky", HelperText = "Approved leave records" },
            new() { Label = "OT Hours This Month", Value = Math.Round(Model.OvertimeMinutesMonth / 60m, 1).ToString("0.0"), Icon = "bi-hourglass-split", Tone = "purple", HelperText = "Overtime logged this month" }
        });
    }
    else
    {
        cards.AddRange(new List<SummaryCardViewModel>
        {
            new() { Label = "Total Employees", Value = Model.TotalUsers.ToString(), Icon = "bi-people", Tone = "neutral", HelperText = "Active employees in scope" },
            new() { Label = $"Present {selectedDateLabel}", Value = Model.PresentCount.ToString(), Icon = "bi-check2-circle", Tone = "success", HelperText = $"Marked present on {selectedDateLabel}" },
            new() { Label = $"Late {selectedDateLabel}", Value = Model.LateCount.ToString(), Icon = "bi-alarm", Tone = "warning", HelperText = $"Arrived after expected time on {selectedDateLabel}" },
            new() { Label = $"Absent {selectedDateLabel}", Value = Model.AbsentCount.ToString(), Icon = "bi-x-circle", Tone = "danger", HelperText = $"No attendance records on {selectedDateLabel}" },
            new() { Label = $"On Leave {selectedDateLabel}", Value = Model.OnLeaveCount.ToString(), Icon = "bi-person-dash", Tone = "sky", HelperText = $"Approved leave for {selectedDateLabel}" },
            new() { Label = "OT Hours This Month", Value = Math.Round(Model.OvertimeMinutesMonth / 60m, 1).ToString("0.0"), Icon = "bi-hourglass-split", Tone = "purple", HelperText = "Total overtime this month" }
        });
    }

    var attendanceTrendPanel = new ChartPanelViewModel
    {
        Title = "Monthly Attendance Trend",
        Subtitle = "Daily movement of present, late, and absent records",
        Meta = $"{Model.TrendLabels.Count} days",
        CanvasId = "attendanceTrendChart"
    };
    var dailyStatusPanel = new ChartPanelViewModel
    {
        Title = "Daily Attendance and OT Trend",
        Subtitle = "Bars for status volumes plus line for overtime hours",
        Meta = "Combined chart",
        CanvasId = "statusBarChart"
    };
    var distributionPanel = new ChartPanelViewModel
    {
        Title = "Attendance Distribution",
        Subtitle = "Status split for the current month",
        Meta = "Month to date",
        CanvasId = "distributionChart",
        HeightClass = "chart-size-md"
    };

    var noSectionData = new EmptyStateViewModel
    {
        Icon = "bi-diagram-3",
        Title = "No section activity found",
        Description = "Section-level attendance is not available for the selected scope today."
    };
    var noActivityData = new EmptyStateViewModel
    {
        Icon = "bi-clock-history",
        Title = "No recent activity yet",
        Description = "Recent attendance activity will appear here once entries are captured."
    };

    string StatusTone(string status) => status switch
    {
        AttendanceStatus.Present => "success",
        AttendanceStatus.Late => "warning",
        AttendanceStatus.Absent => "danger",
        AttendanceStatus.Leave => "neutral",
        _ => "neutral"
    };
}

<section class="dashboard-shell">
    <partial name="_PageHeader" model="header" />

    <!-- Date Filter Form -->
    <form method="get" asp-action="Index" class="dashboard-date-filter mb-4">
        <div class="row align-items-center">
            <div class="col-auto">
                <label for="selectedDate" class="form-label mb-0 fw-semibold">View Dashboard Date:</label>
            </div>
            <div class="col-auto">
                <input type="date"
                       id="selectedDate"
                       name="selectedDate"
                       class="form-control"
                       value="@Model.SelectedDate.ToString("yyyy-MM-dd")"
                       onchange="this.form.submit()" />
            </div>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.WorkerSearchMessage))
    {
        <div class="alert alert-info mt-3">
            @Model.WorkerSearchMessage
        </div>
    }

    @if (Model.WorkerHistorySearchResult != null)
    {
        var worker = Model.WorkerHistorySearchResult;

        <div class="card mt-3 shadow-sm border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0">Worker Attendance History</h5>
                <small>Service ID: @worker.ServiceId</small>
            </div>

            <div class="card-body">
                <div class="row g-3 mb-4">
                    <div class="col-md-2">
                        <strong>Worker ID</strong>
                        <div>@worker.WorkerId</div>
                    </div>
                    <div class="col-md-3">
                        <strong>Name</strong>
                        <div>@worker.FullName</div>
                    </div>
                    <div class="col-md-3">
                        <strong>Email</strong>
                        <div>@worker.Email</div>
                    </div>
                    <div class="col-md-2">
                        <strong>Section</strong>
                        <div>@worker.SectionName</div>
                    </div>
                    <div class="col-md-1">
                        <strong>Worked</strong>
                        <div>@worker.TotalWorkedHours h</div>
                    </div>
                    <div class="col-md-1">
                        <strong>OT</strong>
                        <div>@worker.TotalOTHours h</div>
                    </div>
                </div>

                @if (worker.History.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>In Time</th>
                                    <th>Out Time</th>
                                    <th>Worked Hours</th>
                                    <th>OT Hours</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in worker.History)
                                {
                                    <tr>
                                        <td>@row.Date.ToString("dd MMM yyyy")</td>
                                        <td>@row.InTime</td>
                                        <td>@row.OutTime</td>
                                        <td>@row.WorkedHours</td>
                                        <td>@row.OTHours</td>
                                        <td>@row.Status</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    <section class="summary-grid">
        @foreach (var card in cards)
        {
            <partial name="_SummaryCard" model="card" />
        }
    </section>

    <section class="dashboard-analytics-grid">
        <div class="analytics-main">
            <partial name="_ChartPanel" model="attendanceTrendPanel" />
        </div>
        <aside class="analytics-side">
            <article class="panel-card monthly-progress-card">
                <header class="panel-header">
                    <div>
                        <h2>Monthly Progress</h2>
                        <p class="panel-subtitle">Working-day performance and attendance reliability</p>
                    </div>
                    <span class="panel-meta">@currentMonthLabel</span>
                </header>
                <div class="panel-body">
                    <div class="progress-hero">
                        <div>
                            <p class="tiny-label">Attendance Rate</p>
                            <h3 class="metric-large">@attendanceRate.ToString("0.0")%</h3>
                        </div>
                        <div>
                            <p class="tiny-label">OT Hours</p>
                            <h3 class="metric-large">@Math.Round(Model.OvertimeMinutesMonth / 60m, 1).ToString("0.0")h</h3>
                        </div>
                    </div>
                    <div class="progress modern-progress mb-4" role="progressbar" aria-label="Monthly attendance rate" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@attendanceRate">
                        <div class="progress-bar" style="width:@attendanceRate%;"></div>
                    </div>

                    <div class="mini-stats-grid">
                        <div class="mini-stat">
                            <p class="mini-stats-label">Working Days</p>
                            <h4>@Model.WorkingDaysToDate</h4>
                        </div>
                        <div class="mini-stat">
                            <p class="mini-stats-label">Attended Days</p>
                            <h4>@Model.AttendedDaysToDate</h4>
                        </div>
                        <div class="mini-stat">
                            <p class="mini-stats-label">Present</p>
                            <h4>@Model.MonthlyPresentCount</h4>
                        </div>
                        <div class="mini-stat">
                            <p class="mini-stats-label">Late</p>
                            <h4>@Model.MonthlyLateCount</h4>
                        </div>
                        <div class="mini-stat">
                            <p class="mini-stats-label">Absent</p>
                            <h4>@Model.MonthlyAbsentCount</h4>
                        </div>
                        <div class="mini-stat">
                            <p class="mini-stats-label">Records Today</p>
                            <h4>@Model.TodayAttendance</h4>
                        </div>
                    </div>
                </div>
            </article>
        </aside>
    </section>

    <section class="dashboard-charts-grid">
        <partial name="_ChartPanel" model="dailyStatusPanel" />
        <partial name="_ChartPanel" model="distributionPanel" />
    </section>

    <section class="dashboard-insights-grid">
        @if (!Model.IsWorker)
        {
            <article class="panel-card">
                <header class="panel-header">
                    <div>
                        <h2>Section Summary</h2>
                        <p class="panel-subtitle">Today by section with present, late, and absent totals</p>
                    </div>
                </header>
                <div class="panel-body">
                    @if (Model.SectionSnapshots.Any())
                    {
                        <div class="table-responsive insight-table-wrap">
                            <table class="table table-modern mb-0">
                                <thead>
                                    <tr>
                                        <th>Section</th>
                                        <th>Present</th>
                                        <th>Late</th>
                                        <th>Absent</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.SectionSnapshots)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@item.SectionName</td>
                                            <td><span class="badge-soft badge-soft-success">@item.PresentCount</span></td>
                                            <td><span class="badge-soft badge-soft-warning">@item.LateCount</span></td>
                                            <td><span class="badge-soft badge-soft-danger">@item.AbsentCount</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <partial name="_EmptyState" model="noSectionData" />
                    }
                </div>
            </article>
        }

        <article class="panel-card">
            <header class="panel-header">
                <div>
                    <h2>@(Model.IsWorker ? "My Recent Activity" : "Recent Attendance Activity")</h2>
                    <p class="panel-subtitle">Most recent attendance updates from today's records</p>
                </div>
            </header>
            <div class="panel-body">
                @if (Model.RecentAttendance.Any())
                {
                    <div class="activity-list">
                        @foreach (var item in Model.RecentAttendance)
                        {
                            var statusBadge = new StatusBadgeViewModel { Status = item.Status, Tone = StatusTone(item.Status) };

                            <article class="activity-item">
                                <div>
                                    <h4>@item.EmployeeName</h4>
                                    <p>Section: @(item.SectionName ?? "N/A") | In: @(item.InTime?.ToString(@"hh\:mm") ?? "-") | Out: @(item.OutTime?.ToString(@"hh\:mm") ?? "-")</p>
                                </div>
                                <partial name="_StatusBadge" model="statusBadge" />
                            </article>
                        }
                    </div>
                }
                else
                {
                    <partial name="_EmptyState" model="noActivityData" />
                }
            </div>
        </article>
    </section>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.TrendLabels));
        const presentData = @Html.Raw(JsonSerializer.Serialize(Model.PresentTrend));
        const lateData = @Html.Raw(JsonSerializer.Serialize(Model.LateTrend));
        const absentData = @Html.Raw(JsonSerializer.Serialize(Model.AbsentTrend));
        const overtimeData = @Html.Raw(JsonSerializer.Serialize(Model.OvertimeTrendHours));
        const distributionLabels = @Html.Raw(JsonSerializer.Serialize(Model.DistributionLabels));
        const distributionValues = @Html.Raw(JsonSerializer.Serialize(Model.DistributionValues));

        const commonGridColor = "rgba(95, 122, 160, 0.18)";
        const commonTickColor = "#5f6f87";
        const commonLegend = {
            position: "bottom",
            labels: {
                usePointStyle: true,
                pointStyle: "circle",
                boxWidth: 10,
                color: "#34415a",
                font: {
                    family: "Public Sans",
                    size: 12
                }
            }
        };

        const commonScales = {
            x: {
                ticks: { color: commonTickColor, maxRotation: 0, autoSkipPadding: 18 },
                grid: { display: false }
            },
            y: {
                beginAtZero: true,
                ticks: { precision: 0, color: commonTickColor },
                grid: { color: commonGridColor }
            }
        };

        const trendElement = document.getElementById("attendanceTrendChart");
        if (trendElement) {
            new Chart(trendElement, {
                type: "line",
                data: {
                    labels,
                    datasets: [
                        {
                            label: "Present",
                            data: presentData,
                            borderColor: "#0b9967",
                            backgroundColor: "rgba(11, 153, 103, 0.14)",
                            pointRadius: 2,
                            pointHoverRadius: 4,
                            fill: true,
                            tension: 0.34
                        },
                        {
                            label: "Late",
                            data: lateData,
                            borderColor: "#d08910",
                            backgroundColor: "rgba(208, 137, 16, 0.08)",
                            pointRadius: 2,
                            pointHoverRadius: 4,
                            fill: false,
                            tension: 0.32
                        },
                        {
                            label: "Absent",
                            data: absentData,
                            borderColor: "#cd3246",
                            backgroundColor: "rgba(205, 50, 70, 0.09)",
                            pointRadius: 2,
                            pointHoverRadius: 4,
                            fill: false,
                            tension: 0.3
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: "index",
                        intersect: false
                    },
                    plugins: {
                        legend: commonLegend,
                        tooltip: {
                            backgroundColor: "#10233f",
                            titleFont: { family: "Outfit" },
                            bodyFont: { family: "Public Sans" }
                        }
                    },
                    scales: commonScales
                }
            });
        }

        const statusElement = document.getElementById("statusBarChart");
        if (statusElement) {
            new Chart(statusElement, {
                data: {
                    labels,
                    datasets: [
                        {
                            type: "bar",
                            label: "Present",
                            data: presentData,
                            backgroundColor: "rgba(11, 153, 103, 0.82)",
                            borderRadius: 8
                        },
                        {
                            type: "bar",
                            label: "Late",
                            data: lateData,
                            backgroundColor: "rgba(208, 137, 16, 0.78)",
                            borderRadius: 8
                        },
                        {
                            type: "bar",
                            label: "Absent",
                            data: absentData,
                            backgroundColor: "rgba(205, 50, 70, 0.78)",
                            borderRadius: 8
                        },
                        {
                            type: "line",
                            label: "OT Hours",
                            data: overtimeData,
                            borderColor: "#275fd0",
                            backgroundColor: "rgba(39, 95, 208, 0.10)",
                            yAxisID: "y1",
                            pointRadius: 2,
                            pointHoverRadius: 4,
                            tension: 0.3
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: "index",
                        intersect: false
                    },
                    plugins: {
                        legend: commonLegend
                    },
                    scales: {
                        ...commonScales,
                        y1: {
                            beginAtZero: true,
                            position: "right",
                            grid: { drawOnChartArea: false },
                            ticks: { precision: 0, color: commonTickColor }
                        }
                    }
                }
            });
        }

        const distributionElement = document.getElementById("distributionChart");
        if (distributionElement) {
            new Chart(distributionElement, {
                type: "doughnut",
                data: {
                    labels: distributionLabels,
                    datasets: [
                        {
                            data: distributionValues,
                            borderWidth: 0,
                            backgroundColor: ["#0b9967", "#d08910", "#cd3246", "#6e7f99"],
                            hoverOffset: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: "65%",
                    plugins: {
                        legend: commonLegend
                    }
                }
            });
        }
    </script>
}

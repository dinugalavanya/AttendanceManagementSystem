@model List<AttendanceManagementSystem.Controllers.UserListItemViewModel>
@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-people"></i> User Management</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Showing live data from the Users table.</p>

                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Section</th>
                                        <th>Status</th>
                                        <th>Last Login</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model)
                                    {
                                        <tr>
                                            <td>@user.Id</td>
                                            <td>@user.FullName</td>
                                            <td>@user.Email</td>
                                            <td>@user.RoleName</td>
                                            <td>@user.SectionName</td>
                                            <td>
                                                @if (user.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td>@(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                            <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-people" style="font-size: 3rem; color: var(--primary-color);"></i>
                            <h5 class="mt-3">No users found</h5>
                            <p class="text-muted">No records are currently available in the Users table.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

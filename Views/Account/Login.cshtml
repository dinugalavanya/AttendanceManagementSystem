@model AttendanceManagementSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Login - PulseHR</title>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
* { box-sizing: border-box; }

body {
    margin: 0;
    min-height: 100vh;
    font-family: 'Segoe UI', sans-serif;
    background:
        radial-gradient(circle at top left, rgba(148,163,184,.55), transparent 32%),
        radial-gradient(circle at top right, rgba(209,250,229,.55), transparent 28%),
        linear-gradient(135deg, #0f172a, #020617);
    color: #fff;
    overflow: hidden;
}

.login-wrapper {
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 130px;
    padding: 40px;
}

.lamp-area {
    width: 380px;
    height: 540px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

.lamp {
    position: relative;
    width: 300px;
    height: 470px;
}

.lamp-glow {
    position: absolute;
    top: 120px;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255,221,120,.42), transparent 70%);
    opacity: 0;
    transition: .45s ease;
    filter: blur(10px);
}

.lamp-shade {
    position: absolute;
    top: 70px;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 110px;
    background: linear-gradient(180deg, #f8fafc 0%, #cbd5e1 58%, #94a3b8 100%);
    clip-path: polygon(18% 0, 82% 0, 100% 100%, 0 100%);
    border-radius: 18px 18px 26px 26px;
    box-shadow:
        inset 0 -16px 25px rgba(15,23,42,.18),
        0 12px 30px rgba(0,0,0,.35);
    z-index: 10;
    transition: .45s ease;
}

.lamp-shade::after {
    content: "";
    position: absolute;
    left: 8%;
    bottom: 0;
    width: 84%;
    height: 9px;
    background: rgba(15,23,42,.35);
    border-radius: 50%;
}

.lamp-light {
    position: absolute;
    top: 165px;
    left: 50%;
    transform: translateX(-50%);
    width: 310px;
    height: 260px;
    background: linear-gradient(180deg, rgba(255,221,120,.45), rgba(255,221,120,.08), transparent);
    clip-path: polygon(35% 0, 65% 0, 100% 100%, 0 100%);
    opacity: 0;
    filter: blur(2px);
    transition: .45s ease;
    z-index: 1;
}

.lamp-neck {
    position: absolute;
    top: 176px;
    left: 50%;
    transform: translateX(-50%);
    width: 52px;
    height: 22px;
    background: linear-gradient(180deg, #64748b, #334155);
    border-radius: 0 0 18px 18px;
    z-index: 8;
}

.lamp-pole {
    position: absolute;
    top: 195px;
    left: 50%;
    transform: translateX(-50%);
    width: 13px;
    height: 190px;
    background: linear-gradient(90deg, #64748b, #e2e8f0, #475569);
    border-radius: 20px;
    box-shadow: 0 0 12px rgba(255,255,255,.18);
    z-index: 4;
}

.lamp-base {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    width: 165px;
    height: 44px;
    background: linear-gradient(180deg, #cbd5e1, #64748b);
    border-radius: 50%;
    box-shadow:
        inset 0 -8px 16px rgba(15,23,42,.35),
        0 18px 30px rgba(0,0,0,.45);
    z-index: 4;
}

.lamp-base::after {
    content: "";
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 18px;
    background: rgba(255,255,255,.28);
    border-radius: 50%;
}

/* PERFECT FIXED PULL CORD */
.red-cord {
    position: absolute;
    top: 162px;
    left: calc(50% + 54px);
    width: 36px;
    height: 220px;
    z-index: 50;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    overflow: visible;
}

/* top piece: fixed to lamp */
.red-cord::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: 10px;
    height: 24px;
    transform: translateX(-50%);
    background: #ef233c;
    border-radius: 10px;
    box-shadow: 0 0 8px rgba(239,35,60,.7);
}

/* rope: starts fixed, grows only downward */
.red-string {
    position: absolute;
    top: 22px;
    left: 50%;
    width: 5px;
    height: 105px;
    transform: translateX(-50%);
    background: #ef233c;
    border-radius: 10px;
    box-shadow: 0 0 8px rgba(239,35,60,.7);
    transition: height .35s ease;
}

/* knob: moves down with rope bottom */
.red-knob {
    position: absolute;
    top: 125px;
    left: 50%;
    width: 24px;
    height: 24px;
    transform: translateX(-50%);
    background: #ef233c;
    border-radius: 50%;
    box-shadow: 0 0 16px rgba(239,35,60,.95);
    transition: top .35s ease;
}

.red-knob::after {
    content: "";
    position: absolute;
    width: 7px;
    height: 7px;
    background: rgba(0,0,0,.28);
    border-radius: 50%;
    top: 8px;
    left: 8px;
}

/* only bottom goes down */
.red-cord.pulling .red-string {
    height: 145px;
}

.red-cord.pulling .red-knob {
    top: 165px;
}

.hint {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    color: #cbd5e1;
    font-size: 14px;
    opacity: .75;
    white-space: nowrap;
}

body.lamp-on .lamp-glow,
body.lamp-on .lamp-light {
    opacity: 1;
}

body.lamp-on .lamp-shade {
    box-shadow:
        inset 0 -16px 30px rgba(245,158,11,.28),
        0 0 60px rgba(255,221,120,.75),
        0 12px 30px rgba(0,0,0,.35);
}

body.lamp-on .hint {
    opacity: 0;
}

.login-card {
    width: 620px;
    padding: 50px;
    border-radius: 28px;
    background: rgba(15,23,42,.92);
    border: 1px solid rgba(96,165,250,.45);
    box-shadow: 0 0 55px rgba(59,130,246,.38);
    backdrop-filter: blur(14px);
    opacity: 0;
    transform: translateY(25px) scale(.94);
    pointer-events: none;
    transition: .45s ease;
}

body.lamp-on .login-card {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
}

.brand {
    text-align: center;
    margin-bottom: 32px;
}

.brand h1 {
    margin: 0;
    color: #3b82f6;
    font-size: 48px;
    font-weight: 800;
}

.brand h2 {
    margin: 12px 0 0;
    color: #fff;
    font-size: 32px;
}

.form-group {
    margin-bottom: 24px;
}

.form-label {
    display: block;
    color: #e2e8f0;
    margin-bottom: 10px;
    font-size: 20px;
    font-weight: 600;
}

.input-group {
    display: flex;
    width: 100%;
}

.input-group-text {
    width: 72px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #111827;
    border: 1px solid #334155;
    border-right: none;
    color: #93c5fd;
    border-radius: 16px 0 0 16px;
    font-size: 28px;
}

.form-control {
    width: 100%;
    height: 64px;
    background: #eaf2ff;
    border: 1px solid #334155;
    border-left: none;
    border-radius: 0 16px 16px 0;
    padding: 0 24px;
    color: #020617;
    outline: none;
    font-size: 24px;
}

.form-control:focus {
    box-shadow: 0 0 0 4px rgba(59,130,246,.38);
}

.form-check {
    display: flex;
    align-items: center;
    gap: 14px;
}

.form-check-input {
    width: 18px;
    height: 18px;
}

.form-check-label {
    color: #cbd5e1;
    font-size: 20px;
}

.login-btn {
    width: 100%;
    height: 68px;
    border: none;
    border-radius: 16px;
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    color: white;
    font-size: 24px;
    font-weight: 800;
    cursor: pointer;
    transition: .25s;
}

.login-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 25px rgba(59,130,246,.65);
}

.credentials {
    margin-top: 32px;
    text-align: center;
    color: #94a3b8;
    font-size: 20px;
    line-height: 1.8;
}

.credentials strong {
    color: #a8b5c8;
}

.text-danger {
    color: #f87171 !important;
    font-size: 15px;
    margin-top: 6px;
}

@@media (max-width: 1100px) {
    body { overflow-y: auto; }

    .login-wrapper {
        flex-direction: column;
        gap: 20px;
        padding: 25px;
    }

    .lamp-area {
        height: 360px;
    }

    .lamp {
        transform: scale(.72);
    }

    .login-card {
        width: 100%;
        max-width: 620px;
        padding: 40px;
    }

    .brand h1 {
        font-size: 42px;
    }

    .brand h2 {
        font-size: 28px;
    }

    .form-label,
    .form-check-label,
    .credentials {
        font-size: 17px;
    }

    .form-control,
    .login-btn {
        font-size: 20px;
    }
}
</style>
</head>

<body>
<main class="login-wrapper">

    <section class="lamp-area">
        <div class="lamp">
            <div class="lamp-glow"></div>
            <div class="lamp-shade"></div>
            <div class="lamp-light"></div>
            <div class="lamp-neck"></div>
            <div class="lamp-pole"></div>
            <div class="lamp-base"></div>

            <button type="button" class="red-cord" id="lampSwitch" aria-label="Toggle login lamp">
                <span class="red-string"></span>
                <span class="red-knob"></span>
            </button>
        </div>

        <div class="hint">Pull the red cord to login</div>
    </section>

    <section class="login-card">
        <div class="brand">
            <h1>PulseHR</h1>
            <h2>Welcome Back</h2>
        </div>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-lock"></i>
                    </span>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>
            </div>

            <button type="submit" class="login-btn">
                <i class="bi bi-box-arrow-in-right"></i> Sign In
            </button>
        </form>

        <div class="credentials">
            <strong>Default Credentials:</strong><br />
            Super Admin: superadmin@attendance.com / Admin@123<br />
            dinugavithana578@gmail.com / 123
        </div>
    </section>

</main>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<script>
    const lampSwitch = document.getElementById("lampSwitch");

    lampSwitch.addEventListener("click", function () {
        lampSwitch.classList.add("pulling");

        setTimeout(function () {
            document.body.classList.toggle("lamp-on");
        }, 180);

        setTimeout(function () {
            lampSwitch.classList.remove("pulling");
        }, 430);
    });
</script>

@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
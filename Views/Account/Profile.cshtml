@using AttendanceManagementSystem.Models
@{
    ViewData["Title"] = "Profile";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-person-circle"></i> My Profile</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <div class="profile-avatar">
                                <i class="bi bi-person-circle" style="font-size: 5rem; color: var(--primary-color);"></i>
                            </div>
                            <h4 class="mt-3">@(User?.Identity?.Name ?? "User")</h4>
                            <p class="text-muted">@(User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Unknown Role")</p>
                        </div>
                        <div class="col-md-8">
                            <div class="profile-info">
                                <h6>Profile Information</h6>
                                <hr>
                                <div class="row mb-3">
                                    <div class="col-sm-3"><strong>Email:</strong></div>
                                    <div class="col-sm-9">@(User?.Identity?.Name ?? "N/A")</div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-3"><strong>First Name:</strong></div>
                                    <div class="col-sm-9">@(User?.Claims?.FirstOrDefault(c => c.Type == "FirstName")?.Value ?? "N/A")</div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-3"><strong>Last Name:</strong></div>
                                    <div class="col-sm-9">@(User?.Claims?.FirstOrDefault(c => c.Type == "LastName")?.Value ?? "N/A")</div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-3"><strong>Role:</strong></div>
                                    <div class="col-sm-9">
                                        <span class="badge bg-primary">@(User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Unknown")</span>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-3"><strong>Section:</strong></div>
                                    <div class="col-sm-9">@(User?.Claims?.FirstOrDefault(c => c.Type == "SectionId")?.Value != "0" ? "Section " + User?.Claims?.FirstOrDefault(c => c.Type == "SectionId")?.Value : "No Section")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4">
                        <a href="javascript:history.back()" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
